params {
    input = "/home/jasonday/Barenbrug_Nextflow_Pipeline/main/data/bam_samplesheet.csv"
    reference_genome = "/home/jasonday/Barenbrug_Nextflow_Pipeline/main/data/iso2_polished_racon.fasta"
    genome_gene_bed_file = "/home/jasonday/Barenbrug_Nextflow_Pipeline/main/data/NEA56_genes.bed"
    outdir = "/home/jasonday/Barenbrug_Nextflow_Pipeline/main/results_from_bam"  

    // Variant filtering parameters
    min_allele_balance = 0.2
    max_allele_balance = 0.8
    min_allele_frequency = 0.05
    min_quality = 30
    min_depth = 20
    depth_multiplier = 2
    flanking_region = 100
}

// Enable Docker
docker {
    enabled = true
    runOptions = '-u $(id -u):$(id -g)'
}

// Disable conda and apptainer
conda.enabled = false
apptainer.enabled = false

// Default executor for local runs
executor {
    name = 'local'
}

// Global defaults
process {
    cpus = 2
    memory = 4.GB
    time = 2.h
    maxForks = 2
    errorStrategy = 'terminate'
    shell = ['/bin/bash', '-euo', 'pipefail']
}

// Resource-heavy process tuning
process {
    withName: 'FREEBAYES' {
        cpus = 2
        memory = 8.GB
        time = 16.h
    }
    withName: 'EXTRACT_KASP_MARKERS' {
        cpus = 1
        memory = 4.GB
        time = 2.h
    }
    withName: 'BCFTOOLS_FILTER_GENES' {
        cpus = 1
        memory = 2.GB
        time = 1.h
    }
}

// Docker images per process
process {
    withName: 'SAMTOOLS_.*' {
        container = 'community.wave.seqera.io/library/samtools:1.21--0d76da7c3cf7751c'
    }
    withName: 'MOSDEPTH' {
        container = 'community.wave.seqera.io/library/mosdepth:0.3.10--259732f342cfce27'
    }
    withName: 'FREEBAYES' {
        container = 'community.wave.seqera.io/library/freebayes:1.0.2--976eadffa9ae21c6'
    }
    withName: 'BCFTOOLS_.*' {
        container = 'community.wave.seqera.io/library/bcftools:1.21--4335bec1d7b44d11'
    }
    withName: 'EXTRACT_KASP_MARKERS' {
        container = 'community.wave.seqera.io/library/pysam:0.22.0--a94c5bab35035aad'
    }
    withName: 'MULTIQC' {
        container = 'community.wave.seqera.io/library/multiqc:1.28--77be943f40819715'
    }
}

// Reports
timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}
report {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}
trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}
dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/pipeline_dag.svg"
    overwrite = true
}

profiles {
    standard {
        process.executor = 'local'
    }
    
    hpc {
        process.executor = 'pbs'
        process {
            cpus = 2
            memory = 4.GB
            time = 2.h
        }
    }

    test {
        process.executor = 'local'
        process {
            cpus = 1
            memory = 2.GB
            time = 1.h
        }
    }
}

manifest {
    name = 'EVAK_pipe_from_bam'
    author = 'Jason Day'
    homePage = ''
    description = 'Variant calling pipeline starting from BAM files with gene filtering and KASP marker extraction'
    mainScript = 'EVAK_bam_pipe.nf'
    nextflowVersion = '>=21.10.3'
    version = '1.0.0'
}